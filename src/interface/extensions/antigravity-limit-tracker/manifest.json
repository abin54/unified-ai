{
  "manifest_version": 3,
  "name": "AI Limit Tracker",
  "version": "1.0.0",
  "description": "Track your AI model usage limits from local service",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AI Usage Dashboard"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:*/*"
  ]
}
