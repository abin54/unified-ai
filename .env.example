# Unified AI Ecosystem - Environment Variables
# Copy this to .env and fill in your keys

# --- Core LLM Providers ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
HF_TOKEN=hf_...

# --- Research & Security API Keys ---
S2_API_KEY=...             # Semantic Scholar API (for advanced paper searches)
TAVILY_API_KEY=tvly-...    # For web search tools
GITHUB_TOKEN=ghp_...       # For GitHub MCP and search tools

# --- Database & RAG Configuration ---
CHROMA_DB_PATH=./src/memory/chroma_db
LIGHTRAG_WORKING_DIR=./src/memory/lightrag_data

# --- Application Settings ---
LOG_LEVEL=INFO
YOLO_MODE=false            # Set to true to skip tool execution approvals
STREAM_OUTPUT=true
